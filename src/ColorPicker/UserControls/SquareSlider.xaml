<UserControl x:Class="ColorPicker.UserControls.SquareSlider"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ColorPicker.Converters"
             x:ClassModifier="internal"
             x:Name="uc">
    <UserControl.Resources>
        <conv:ProportialConverter x:Key="ProportionalConverter" />
    </UserControl.Resources>

    <Border CornerRadius="4" ClipToBounds="True" BorderThickness="1" BorderBrush="#3F3F46">
        <Grid MouseDown="OnMouseDown" MouseMove="OnMouseMove" MouseUp="OnMouseUp" Background="Transparent">
            <Image Source="{Binding ElementName=uc, Path=GradientBitmap}" Stretch="Fill" />

            <Canvas IsHitTestVisible="False">
                <Grid x:Name="head">
                    <Canvas.Left>
                        <MultiBinding Converter="{StaticResource ProportionalConverter}">
                            <Binding ElementName="uc" Path="ActualWidth" />
                            <Binding ElementName="uc" Path="HeadX" />
                            <Binding ElementName="uc" Path="RangeX" />
                        </MultiBinding>
                    </Canvas.Left>
                    <Canvas.Top>
                        <MultiBinding Converter="{StaticResource ProportionalConverter}">
                            <Binding ElementName="uc" Path="ActualHeight" />
                            <Binding ElementName="uc" Path="HeadY" />
                            <Binding ElementName="uc" Path="RangeY" />
                            <Binding Source="True" />
                        </MultiBinding>
                    </Canvas.Top>

                    <Ellipse Stroke="White" StrokeThickness="2" Width="12" Height="12" Margin="-6,-6">
                        <Ellipse.Effect>
                            <DropShadowEffect BlurRadius="4" ShadowDepth="0" Opacity="0.6"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <Ellipse Stroke="#202020" StrokeThickness="1" Width="14" Height="14" Margin="-7,-7" />
                </Grid>
            </Canvas>
        </Grid>
    </Border>
</UserControl>